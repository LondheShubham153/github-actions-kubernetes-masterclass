# STAGE ENVIRONMENT - Docker Ubuntu
# Copy this to .env.stage and fill in your values

# Docker Hub
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_token

# Database
MYSQL_ROOT_PASSWORD=root_password_stage
DB_NAME=skillpulse_stage
DB_USER=skillpulse_stage
DB_PASSWORD=skillpulse_stage_pwd

# App
PORT=8080
ENVIRONMENT=stage
